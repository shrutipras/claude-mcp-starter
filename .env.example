# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
# Before launching Claude Code, run: source .env.local

# Google Workspace MCP (required)
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Optional: lock workspace-mcp to a specific Google account
# USER_GOOGLE_EMAIL=you@gmail.com

# GitHub MCP — only needed if you don't have GitHub Copilot
# and are using the Docker-based alternative (see README).
# Create a PAT at https://github.com/settings/tokens
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
